{
    "$schema": "https://getcomposer.org/schema/json",
    "name": "ditshej/op-cards-php",
    "description": "PHP SDK for the One Piece TCG card API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "illuminate/config": "^10.0|^11.0|^12.0",
        "illuminate/container": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.0"
    },
    "suggest": {
        "illuminate/support": "Required to use the Laravel ServiceProvider and Facade (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "Ditshej\\OpCards\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --compact",
        "lint": "vendor/bin/pint",
        "setup": [
            "@composer install",
            "npm install",
            "git config core.hooksPath .githooks"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ditshej\\OpCards\\Laravel\\OpCardsServiceProvider"
            ],
            "aliases": {
                "OpCards": "Ditshej\\OpCards\\Laravel\\Facades\\OpCards"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
